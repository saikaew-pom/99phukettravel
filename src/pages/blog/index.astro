---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogArchive from '../../components/BlogArchive';
import SEOhead from '../../components/SEOhead';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map(post => ({
    id: post.id,
    slug: post.id,
    data: post.data
  }));

const title = "Expert Phuket Travel Guides | 99event.co";
const description = "Explore our comprehensive collection of Phuket travel guides, from hidden beaches to local food secrets.";
---

<BaseLayout title={title} description={description} maxWidth="max-w-7xl">
  <SEOhead 
    slot="head" 
    title={title} 
    description={description} 
    canonicalUrl={Astro.url.toString()}
    type="website"
  />

  <div class="mb-16">
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-4">
      The <span class="italic font-serif">Journal</span>
    </h1>
    <p class="text-xl text-gray-500 max-w-2xl leading-relaxed">
      Authentic stories, expert advice, and deep dives into everything that makes Phuket extraordinary.
    </p>
  </div>

  <BlogArchive client:load posts={posts} />
</BaseLayout>

---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	maxWidth?: string;
}

const { 
	title, 
	description = "A minimalist blog built with Astro, React, and Tailwind CSS.",
	maxWidth = "max-w-4xl"
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{title && !Astro.slots.has('head') && <title>{title}</title>}
		{description && !Astro.slots.has('head') && <meta name="description" content={description} />}
		<slot name="head" />
	</head>
	<body class="bg-white text-gray-900 font-sans antialiased flex flex-col min-h-screen">
		<header class="border-b border-gray-100 bg-white/80 backdrop-blur-md sticky top-0 z-50">
			<nav class={`mx-auto px-6 h-16 flex items-center justify-between ${maxWidth}`}>
				<a href="/" class="text-xl font-bold tracking-tight hover:opacity-80 transition-opacity">
					99event.co
				</a>
				<div class="flex items-center gap-8 text-sm font-medium">
					<a href="/blog" class="text-gray-600 hover:text-black transition-colors">Blog</a>
					<a href="/about" class="text-gray-600 hover:text-black transition-colors">About</a>
					<button class="bg-black text-white px-4 py-2 rounded-full hover:bg-gray-800 transition-colors">
						Subscribe
					</button>
				</div>
			</nav>
		</header>

		<main class={`flex-grow mx-auto px-6 py-12 w-full ${maxWidth}`}>
			<slot />
		</main>

		<footer class="border-t border-gray-100 py-12 text-center">
			<div class={`mx-auto px-6 ${maxWidth}`}>
				<p class="text-sm text-gray-500 font-medium">
					&copy; {new Date().getFullYear()} 99event.co. Built with 
					<a href="https://astro.build" class="underline underline-offset-4 hover:text-black">Astro</a>.
				</p>
				<div class="mt-6 flex justify-center gap-6">
					<a href="#" class="text-gray-400 hover:text-black transition-colors">Twitter</a>
					<a href="#" class="text-gray-400 hover:text-black transition-colors">GitHub</a>
					<a href="#" class="text-gray-400 hover:text-black transition-colors">LinkedIn</a>
				</div>
			</div>
		</footer>
	</body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOhead from '../components/SEOhead';
import BeachFinder from '../components/BeachFinder';
import AuthorBox from '../components/AuthorBox';

const title = "Discover the Real Phuket | 99event.co";
const description = "Your ultimate guide to the hidden gems, pristine beaches, and local culture of Phuket, Thailand.";
const canonicalUrl = "https://99event.co";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} maxWidth="max-w-7xl">
	<SEOhead
		slot="head"
		title={title}
		description={description}
		canonicalUrl={canonicalUrl}
		type="website"
	/>

	{/* Hero Section */}
	<section class="relative h-[80vh] min-h-[600px] flex items-center justify-center overflow-hidden rounded-3xl mt-4">
		<div class="absolute inset-0 z-0">
			<img
				src={`${base}images/homepage-header.png`}
				alt="Stunning Phuket Beach"
				class="w-full h-full object-cover"
			/>
			<div class="absolute inset-0 bg-black/30 backdrop-blur-[2px]"></div>
		</div>

		<div class="relative z-10 text-center px-6 max-w-3xl">
			<h1 class="text-6xl md:text-7xl font-extrabold text-white tracking-tight mb-6">
				Discover the <span class="italic font-serif">Real</span> Phuket
			</h1>
			<p class="text-xl text-white/90 mb-10 leading-relaxed font-medium">
				Beyond the resorts lies an island of hidden coves, ancient temples, and vibrant street food markets waiting to be explored.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="#explore" class="bg-white text-black px-8 py-4 rounded-full font-bold text-lg hover:bg-gray-100 transition-all shadow-xl hover:scale-105 active:scale-95">
					Start Exploring
				</a>
				<a href={`${base}blog`} class="bg-white/20 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-full font-bold text-lg hover:bg-white/30 transition-all">
					Read the Guides
				</a>
			</div>
		</div>
	</section>

	{/* Interactive Section */}
	<div id="explore" class="scroll-mt-24">
		<BeachFinder client:load />
	</div>

	{/* Recent Guides Section */}
	<section class="py-16 border-t border-gray-100">
		<div class="flex items-center justify-between mb-12">
			<div>
				<h2 class="text-3xl font-bold tracking-tight">Recent Travel Guides</h2>
				<p class="text-gray-500 mt-2">Expert advice for your next Thai adventure.</p>
			</div>
			<a href={`${base}blog`} class="hidden sm:block text-sm font-bold uppercase tracking-widest text-black hover:opacity-60 transition-opacity">
				View All &rarr;
			</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-10">
			{[
				{ title: "The Ultimate Patong Beach Guide", img: `${base}images/beach-patong.png`, category: "Beach Guide", slug: "patong-beach-guide" },
				{ title: "How Much Does Phuket Cost in 2026?", img: "https://images.unsplash.com/photo-1552465011-b4e21bf6e79a?auto=format&fit=crop&q=80&w=600", category: "Budgeting", slug: "phuket-cost-guide-2026" },
				{ title: "Phuket Entry Guide 2026", img: "https://images.unsplash.com/photo-1530789253388-582c481c54b0?auto=format&fit=crop&q=80&w=600", category: "Travel Tips", slug: "phuket-entry-guide-2026" }
			].map((post) => (
				<a href={`${base}blog/${post.slug}`} class="group cursor-pointer">
					<div class="overflow-hidden rounded-2xl mb-4 bg-gray-100 aspect-video">
						<img src={post.img} alt={post.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
					</div>
					<span class="text-xs font-bold text-gray-400 uppercase tracking-widest">{post.category}</span>
					<h3 class="text-xl font-bold mt-2 group-hover:text-gray-600 transition-colors">{post.title}</h3>
					<p class="text-gray-500 mt-2 line-clamp-2 italic">A deep dive into the most authentic experiences Phuket has to offer...</p>
					<div class="mt-4 text-sm font-bold underline underline-offset-4 decoration-2">Read More</div>
				</a>
			))}
		</div>
	</section>

	{/* Trust/E-E-A-T Section */}
	<section class="py-16 border-t border-gray-100 bg-gray-50/50 -mx-6 px-6">
		<div class="max-w-2xl mx-auto text-center mb-12">
			<h2 class="text-3xl font-bold tracking-tight">Local Expertise</h2>
			<p class="text-gray-600 mt-4 text-lg">
				We don't just visit Phuket; we live here. Every recommendation is hand-picked and personally verified.
			</p>
		</div>
		<AuthorBox
			name="Gemini Phuket"
			bio="A long-time resident and travel journalist dedicated to helping travelers discover the authentic side of Thailand's most famous island. From street food to secret sunsets."
			avatarUrl="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=200"
			knowsAbout={["Phuket Travel", "Thai Cuisine", "Sustainable Tourism"]}
			socialLinks={[
				{ platform: "Instagram", url: "https://instagram.com/phuketexplorer" },
				{ platform: "Twitter", url: "https://twitter.com/phuketexplorer" }
			]}
		/>
	</section>
</BaseLayout>

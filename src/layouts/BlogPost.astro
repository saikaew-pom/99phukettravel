---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import SEOhead from '../components/SEOhead';
import SocialShare from '../components/SocialShare.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: string;
	author?: string;
	headings: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, heroImage, author = "Gemini Phuket", headings } = Astro.props;

const base = import.meta.env.BASE_URL;

// Filter headings to show only H2 for the ToC
const tocHeadings = headings.filter(h => h.depth === 2);

// Basic Reading Time Estimation
const readingTime = "5 min read";

// Dynamic Related Articles
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(post => post.data.title !== title) // Exclude current post
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()) // Sort by date
  .slice(0, 2); // Take top 2
---

<BaseLayout title={title} description={description} maxWidth="max-w-7xl">
	<SEOhead
		slot="head"
		title={`${title} | 99event.co`}
		description={description}
		canonicalUrl={Astro.url.toString()}
		ogImage={heroImage}
		publishedDate={pubDate.toISOString()}
		authorName={author}
		type="article"
	/>

	{/* Hero Header */}
	<header class="pt-4 pb-16">
		<div class="max-w-3xl">
			<div class="flex items-center gap-3 text-sm font-bold uppercase tracking-widest text-gray-400 mb-6">
				<time datetime={pubDate.toISOString()}>
					{pubDate.toLocaleDateString('en-us', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</time>
				<span>•</span>
				<span class="text-blue-600">{readingTime}</span>
			</div>
			<h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-8 leading-[1.1]">
				{title}
			</h1>
		</div>

		{heroImage && (
			<div class="rounded-3xl overflow-hidden aspect-[21/9] shadow-2xl bg-gray-100 mt-8">
				<img src={heroImage} alt={title} class="w-full h-full object-cover" />
			</div>
		)}
	</header>

	{/* Main Content & Sidebar */}
	<div class="grid grid-cols-1 lg:grid-cols-12 gap-16 pb-24">

		{/* Left Column: Content */}
		<main class="lg:col-span-8">
			<article class="prose prose-lg prose-blue max-w-none prose-headings:scroll-mt-24">
				<slot />
			</article>

			<SocialShare title={title} url={Astro.url.toString()} />

			{/* Dynamic Related Articles */}
			{relatedPosts.length > 0 && (
				<section class="mt-24 pt-12 border-t border-gray-100">
					<h3 class="text-2xl font-bold mb-8">Continue Exploring</h3>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						{relatedPosts.map((post) => (
							<a href={`${base}blog/${post.id}`} class="group cursor-pointer">
								<div class="aspect-video bg-gray-100 rounded-2xl mb-4 overflow-hidden shadow-sm group-hover:shadow-md transition-all">
									<img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
								</div>
								<h4 class="text-lg font-bold group-hover:text-blue-600 transition-colors leading-snug">
									{post.data.title}
								</h4>
								<p class="text-sm text-gray-500 mt-2 line-clamp-2 italic">
									{post.data.description}
								</p>
							</a>
						))}
					</div>
				</section>
			)}
		</main>

		{/* Right Column: Sticky Sidebar */}
		<aside class="lg:col-span-4">
			<div class="sticky top-24 space-y-12">
				{/* Dynamic Table of Contents */}
				{tocHeadings.length > 0 && (
					<div class="p-8 bg-gray-50 rounded-3xl border border-gray-100">
						<h4 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-6">Table of Contents</h4>
						<nav class="flex flex-col gap-4">
							{tocHeadings.map(heading => (
								<a
									href={`#${heading.slug}`}
									class="text-sm font-medium text-gray-600 hover:text-blue-600 hover:translate-x-1 transition-all"
								>
									{heading.text}
								</a>
							))}
						</nav>
					</div>
				)}

				<div class="p-8 bg-blue-600 rounded-3xl text-white shadow-xl shadow-blue-200">
					<h4 class="text-xl font-bold mb-4">Join the community</h4>
					<p class="text-blue-100 text-sm mb-6 leading-relaxed">
						Get the latest hidden gems and travel tips delivered straight to your inbox.
					</p>
					<button class="w-full py-3 bg-white text-blue-600 rounded-full font-bold hover:bg-blue-50 transition-colors">
						Subscribe
					</button>
				</div>
			</div>
		</aside>
	</div>
</BaseLayout>
